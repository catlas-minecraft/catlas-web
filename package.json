{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "api:dev": "DATABASE_URL=postgresql://catlas:catlas@127.0.0.1:5432/catlas JWT_SECRET=dev-secret node --import tsx/esm packages/api/src/server.ts",
    "clean": "node scripts/clean.mjs",
    "codegen": "pnpm --recursive --parallel run codegen",
    "db:down": "docker compose down",
    "db:down:volumes": "docker compose down -v",
    "db:up": "docker compose up -d",
    "build": "tsc -b tsconfig.build.json && pnpm --recursive --parallel run build",
    "check": "tsc -b tsconfig.json",
    "check-recursive": "pnpm --recursive exec tsc -b tsconfig.json",
    "db:migrate": "pnpm --filter @catlas/db migrate",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@effect/build-utils": "^0.7.7",
    "@effect/language-service": "0.81.0",
    "@effect/vitest": "0.29.0",
    "@types/node": "^22.8.5",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "effect": "^3.10.7",
    "glob": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "patchedDependencies": {}
  }
}
