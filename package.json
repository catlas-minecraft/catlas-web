{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm --recursive --parallel run dev",
    "clean": "node scripts/clean.mjs",
    "codegen": "pnpm --recursive --parallel run codegen",
    "db:down": "docker compose down",
    "db:down:volumes": "docker compose down -v",
    "db:up": "docker compose up -d",
    "build": "tsc -b tsconfig.build.json && pnpm --recursive --parallel run build",
    "check": "tsc -b tsconfig.json",
    "check-recursive": "pnpm --recursive exec tsc -b tsconfig.json",
    "db:migrate": "pnpm --filter @catlas/db migrate",
    "test": "vp test",
    "coverage": "vp test --coverage",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@effect/build-utils": "^0.7.9",
    "@effect/language-service": "0.81.0",
    "@effect/vitest": "0.29.0",
    "@types/node": "^22.19.17",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "effect": "^3.21.1",
    "glob": "^11.1.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.18"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "patchedDependencies": {}
  }
}
