{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "vite/client"
    ],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@catlas/domain": [
        "../domain/src/index.ts"
      ],
      "@catlas/domain/*": [
        "../domain/src/*.ts"
      ],
      "@catlas/leaflet": [
        "../catlas-leaflet/src/index.ts"
      ],
      "@catlas/leaflet/*": [
        "../catlas-leaflet/src/*.ts"
      ],
      "@catlas/schema": [
        "../schema/src/index.ts"
      ],
      "@catlas/schema/*": [
        "../schema/src/*.ts"
      ]
    },
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src"
  ]
}
