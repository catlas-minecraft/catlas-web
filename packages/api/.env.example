DATABASE_URL=postgresql://catlas:catlas@127.0.0.1:5432/catlas
JWT_SECRET=dev-secret

# Enable Effect -> OpenTelemetry export.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=catlas-api
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
# Trace-specific endpoint. If omitted, OTEL_EXPORTER_OTLP_ENDPOINT is used with /v1/traces.
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Shared OTLP base endpoint fallback.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Comma-separated headers: key=value,key2=value2
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=Authorization=Bearer local-token,x-api-key=dev
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer local-token
