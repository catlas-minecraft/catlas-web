{
  "name": "@catlas/api",
  "version": "0.0.0",
  "description": "The server template",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "<PLACEHOLDER>",
    "directory": "packages/api"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "dev": "portless --name api.catlas node --env-file-if-exists=.env --import tsx/esm src/bin/dev.ts",
    "codegen": "build-utils prepare-v2",
    "build": "vp pack",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "vp test",
    "coverage": "vp test --coverage"
  },
  "dependencies": {
    "@catlas/db": "workspace:^",
    "@catlas/domain": "workspace:^",
    "@catlas/louis": "workspace:^",
    "@effect/experimental": "^0.60.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "0.96.0",
    "@effect/platform-node": "0.106.0",
    "@effect/sql": "0.51.0",
    "@effect/sql-kysely": "0.47.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "effect": "3.21.0",
    "kysely": "^0.28.14",
    "portless": "^0.7.2"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
